    <endEvent id="Event_10ae0lt" name="Untersuchung abgeschlossen">
      <documentation>Bei unauffälligem Befund kann die Untersuchung frühestens nach 12 Monaten wiederholt werden (§2 Abs.1 Nr.2).</documentation>
      <extensionElements>
        <i18n:translation lang="de">Untersuchung abgeschlossen</i18n:translation>
