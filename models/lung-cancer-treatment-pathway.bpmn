<bpmn:definitions xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:cp="http://www.helict.de/bpmn4cp" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd" xml:lang="de">
  <bpmn:collaboration id="Collaboration_1cxznoy">
    <bpmn:participant id="Participant_07gxczs" name="Behandlung" processRef="Process_1">
      <bpmn:extensionElements>
        <i18n:translation xml:lang="en">Treatment - Lung Cancer</i18n:translation>
        <i18n:translation xml:lang="de">Behandlung</i18n:translation>
      </bpmn:extensionElements>
    </bpmn:participant>
    <bpmn:textAnnotation id="TextAnnotation_02gcplv">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">inclusive gateway activates one or more
          branches, i.e. combined therapy</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Inklusives Gateway aktiviert einen oder
          mehrere Pfade, d. h. eine Kombinationstherapie</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Inklusives Gateway aktiviert einen oder
          mehrere Pfade, d. h. eine Kombinationstherapie</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1asddeq">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">e.g., in case of malignant pleural effusion,
          hemoptysis, superior vena cava syndrome, tracheobronchial tumour obstruction; specific
          treatment of metastases</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">z. B. bei malignem Pleuraerguss, Hämoptyse,
          Vena-cava-superior-Syndrom, tracheobronchialer Tumorobstruktion; spezifische Behandlung
          von Metastasen</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>z. B. bei malignem Pleuraerguss, Hämoptyse,
          Vena-cava-superior-Syndrom, tracheobronchialer Tumorobstruktion; spezifische Behandlung
          von Metastasen</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0348d32" sourceRef="Activity_1mvnvbc" targetRef="TextAnnotation_1asddeq" />
    <bpmn:textAnnotation id="TextAnnotation_1ltbheu">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">i.e., all
          active incoming branches of the treatment plan must be
          completed before merging</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">d. h. alle
          aktiven eingehenden Pfade des Behandlungsplans müssen
          vor dem Zusammenführen abgeschlossen sein</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>d. h. alle
          aktiven eingehenden Pfade des Behandlungsplans müssen
          vor dem Zusammenführen abgeschlossen sein</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0m4nli6" sourceRef="Gateway_18pkxio" targetRef="TextAnnotation_02gcplv" />
    <bpmn:association id="Association_1sv6uxf" sourceRef="Gateway_19kiq8e" targetRef="TextAnnotation_1ltbheu" />
  </bpmn:collaboration>
