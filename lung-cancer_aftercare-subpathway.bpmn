  <bpmn2:collaboration id="Collaboration_0jne9lg">
    <bpmn2:participant id="Participant_08m8ex4" name="Nachsorge (Ambulante Versorgung)" processRef="Process_1">
      <bpmn2:extensionElements>
        <i18n:translation lang="de">Nachsorge (Ambulante Versorgung)</i18n:translation>
      </bpmn2:extensionElements>
    </bpmn2:participant>
    <bpmn2:textAnnotation id="TextAnnotation_1kl9ikk">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">- Teilweise nicht vorhanden/übermittelt; muss ggf. angefragt werden
- Unstrukturiertes Dokument (kein Standard vorhanden); wird strukturiert in PVS übertragen
- Inhalt: Anamnese (inkl. Nebenwirkungen der Therapie), CT-Befunde, ggf. Laborergebnisse, Lungenfunktion, wünschenswert: Impfungen, Lebensqualität</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>- Teilweise nicht vorhanden/übermittelt; muss ggf. angefragt werden
- Unstrukturiertes Dokument (kein Standard vorhanden); wird strukturiert in PVS übertragen
- Inhalt: Anamnese (inkl. Nebenwirkungen der Therapie), CT-Befunde, ggf. Laborergebnisse, Lungenfunktion, wünschenswert: Impfungen, Lebensqualität</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0qmicxk">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Medikationsplan ggf. aus ePA abrufen, falls
Zugriffs-berechtigung durch Patient nicht entzogen</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Medikationsplan ggf. aus ePA abrufen, falls
Zugriffs-berechtigung durch Patient nicht entzogen</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1gi9dkd">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">- Seit letztem Besuch:
Aktuelle Symptome /Beschwerden, Komplikationen, sozialmedizinische Aspekte, Medikamentenanamnese, Komorbiditäten
- Optional, falls nicht vorhanden: Familienanamnese</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>- Seit letztem Besuch:
Aktuelle Symptome /Beschwerden, Komplikationen, sozialmedizinische Aspekte, Medikamentenanamnese, Komorbiditäten
- Optional, falls nicht vorhanden: Familienanamnese</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1poit57">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Krankheitsbezogene Diagnostik</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Krankheitsbezogene Diagnostik</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1c44r1w">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Je nach Leitlinie oder Diagnose
          unterschiedliche Intervalldauer</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Je nach Leitlinie oder Diagnose
          unterschiedliche Intervalldauer</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1gkl1qq">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Tertiärprävention; Rauchentwöhnung; DiGA</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Tertiärprävention; Rauchentwöhnung; DiGA</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0nk2czw">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Ggf. Nachsorgeplan per KIM (PDF)</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Ggf. Nachsorgeplan per KIM (PDF)</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0clb061">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Blut-, Leber- und Nierenwerte; spezifisch zu
Symptomen und Nachsorgeplan</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Blut-, Leber- und Nierenwerte; spezifisch zu
Symptomen und Nachsorgeplan</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_073gqs1">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Z.B. Dokument mit QR-Code für Patient</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Z.B. Dokument mit QR-Code für Patient</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1ek9j74">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Einzeltermin; wünschenswert wäre eine
Terminserie, die anhand der Intervalle des Nachsorgeplans vorgeschlagen wird</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Einzeltermin; wünschenswert wäre eine
Terminserie, die anhand der Intervalle des Nachsorgeplans vorgeschlagen wird</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1i5b5m4">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" lang="de">Raucherstatus:
Rauchdauer,
Rauchstopp-Zeitpunkt, Pack-Years (optional, keine klinische Relevanz)</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Raucherstatus:
Rauchdauer,
Rauchstopp-Zeitpunkt, Pack-Years (optional, keine klinische Relevanz)</bpmn2:text>
    </bpmn2:textAnnotation>
