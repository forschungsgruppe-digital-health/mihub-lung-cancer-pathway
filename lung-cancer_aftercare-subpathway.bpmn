  <bpmn2:collaboration id="Collaboration_0jne9lg">
    <bpmn2:participant id="Participant_08m8ex4" name="Hausärztliche Praxis" processRef="Process_1">
      <bpmn2:extensionElements>
        <i18n:translation xml:lang="de">Hausärztliche Praxis</i18n:translation>
      </bpmn2:extensionElements>
    </bpmn2:participant>
    <bpmn2:textAnnotation id="TextAnnotation_0ad39t3">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Fleischner-Kriterien, d.h. zufällig entdeckte Rundherde bei Patienten &gt; 35 Jahre oder Patienten ohne bekannte Krebserkrankung</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Fleischner-Kriterien, d.h. zufällig entdeckte Rundherde bei Patienten &gt; 35 Jahre oder Patienten ohne bekannte Krebserkrankung</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1kl9ikk">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Überwiegende Teil der Patienten kommt ohne Nachsorgeplan; muss angefragt werden; unstrukturiertes Dokument (kein Standard vorhanden); wird strukturiert in PVS übertragen</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Überwiegende Teil der Patienten kommt ohne Nachsorgeplan; muss angefragt werden; unstrukturiertes Dokument (kein Standard vorhanden); wird strukturiert in PVS übertragen</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0qmicxk">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Medikationsplan ggf. aus ePA abrufen, falls Zugriffsberechtigung durch Patient nicht entzogen</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Medikationsplan ggf. aus ePA abrufen, falls Zugriffsberechtigung durch Patient nicht entzogen</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1gi9dkd">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Aktuelle Symptome und Komplikationen, sozialmedizinische Aspekte, Medikamentenanamnese, Familienanamnese, Komorbiditäten</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Aktuelle Symptome und Komplikationen, sozialmedizinische Aspekte, Medikamentenanamnese, Familienanamnese, Komorbiditäten</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1poit57">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Krankheitsbezogene Diagnostik</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Krankheitsbezogene Diagnostik</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1c44r1w">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Je nach Leitlinie oder Diagnose unterschiedliche Intervalldauer</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Je nach Leitlinie oder Diagnose unterschiedliche Intervalldauer</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1gkl1qq">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Tertiärprävention; Rauchentwöhnung; DiGA</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Tertiärprävention; Rauchentwöhnung; DiGA</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1elmqoq" associationDirection="None" sourceRef="Event_042yczc" targetRef="TextAnnotation_0ad39t3" />
    <bpmn2:textAnnotation id="TextAnnotation_0nk2czw">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Nachsorgeplan per E-Mail (PDF); KIM selten genutzt</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Nachsorgeplan per E-Mail (PDF); KIM selten genutzt</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0clb061">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Blut-, Leber- und Nierenwerte; spezifisch zu Symptomen und Nachsorgeplan</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Blut-, Leber- und Nierenwerte; spezifisch zu Symptomen und Nachsorgeplan</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_073gqs1">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Z.B. Dokument mit QR-Code für Patient</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Z.B. Dokument mit QR-Code für Patient</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1ek9j74">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Einzeltermin; wünschenswert wäre eine Terminserie, die anhand der Intervalle des Nachsorgeplans vorgeschlagen wird</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Einzeltermin; wünschenswert wäre eine Terminserie, die anhand der Intervalle des Nachsorgeplans vorgeschlagen wird</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1i5b5m4">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="de">Raucherstatus:Rauchdauer, Rauchstopp-Zeitpunkt, Pack-Years</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Raucherstatus:Rauchdauer, Rauchstopp-Zeitpunkt, Pack-Years</bpmn2:text>
    </bpmn2:textAnnotation>
