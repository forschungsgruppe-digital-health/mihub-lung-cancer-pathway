    <bpmn2:textAnnotation id="TextAnnotation_1kktshw">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">is there really a last ending CCCN care
          consultation after after-care/follow-up?</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Gibt es wirklich noch ein abschließendes
          CCCN-Abschlussgespräch nach Nachsorge/Follow-up?</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Gibt es wirklich noch ein abschließendes
          CCCN-Abschlussgespräch nach Nachsorge/Follow-up?</bpmn2:text>
    </bpmn2:textAnnotation>
