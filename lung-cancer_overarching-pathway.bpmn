    <bpmn2:group id="Group_0wf6myh" categoryValueRef="CategoryValue_116jo7b" />
    <bpmn2:group id="Group_19zxv3g" categoryValueRef="CategoryValue_05ea948" />
    <bpmn2:group id="Group_1nphlqz" categoryValueRef="CategoryValue_0s9m84z" />
    <bpmn2:textAnnotation id="TextAnnotation_16s2jjh">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">held at least once a week [LC SoS 1.2.2.A]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">findet mindestens einmal pro Woche statt [LC SoS 1.2.2.A]</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>findet mindestens einmal pro Woche statt [LC SoS 1.2.2.A]</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0ar7hqt">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">mandatory: after surgical therapy [LC SoS
          1.2.3.A]; molecular tumour board if necessary (see inclusion criteria in subprocess for
          MTB); if necessary incl. staging diagnostics</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">verpflichtend: nach chirurgischer Therapie
[LC SoS 1.2.3.A]; bei Bedarf MTB (siehe Einschlusskriterien im
Teilprozess für das MTB); bei Bedarf inkl. Staging-Diagnostik</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>verpflichtend: nach chirurgischer Therapie
[LC SoS 1.2.3.A]; bei Bedarf MTB (siehe Einschlusskriterien im
Teilprozess für das MTB); bei Bedarf inkl. Staging-Diagnostik</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0si34sk">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">patient information and dialogue [LC SoS
          6.1.16]; diagnosis communication [LC SoS 2.1.5]; therapy options, chances of success and
          possbile effects, offer aid in obtaining second opinion [LC SoS 2.1.4] inform about
          self-help/ patient support groups [LC SoS 1.6.7], explain treatment plan to patient, hand
          out copy [LC SoS 1.2.2.F]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Patienteninformation und
Dialog [LC SoS 6.1.16];
Mitteilung der Diagnose
[LC SoS 2.1.5]; Therapieoptionen, Erfolgsaussichten und mögliche Auswirkungen, Unterstützung
bei der Einholung einer
Zweitmeinung anbieten
[LC SoS 2.1.4]; über Selbsthilfe-/Patientenunterstützungsgruppen informieren [LC SoS 1.6.7],
Behandlungsplan mit dem
Patienten besprechen,
Kopie aushändigen
[LC SoS 1.2.2.F]</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Patienteninformation und
Dialog [LC SoS 6.1.16];
Mitteilung der Diagnose
[LC SoS 2.1.5]; Therapieoptionen, Erfolgsaussichten und mögliche Auswirkungen, Unterstützung
bei der Einholung einer
Zweitmeinung anbieten
[LC SoS 2.1.4]; über Selbsthilfe-/Patientenunterstützungsgruppen informieren [LC SoS 1.6.7],
Behandlungsplan mit dem
Patienten besprechen,
Kopie aushändigen
[LC SoS 1.2.2.F]</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_08q0dpe" associationDirection="None" sourceRef="Activity_1oagskd" targetRef="TextAnnotation_16s2jjh" />
    <bpmn2:textAnnotation id="TextAnnotation_1t1txqb">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Can be offered to well-informed heavy smokers
          aged 55 to 74 years
          within a special programme in experienced CT centres (ESMO)</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Kann gut informierten starken Rauchern im
Alter von 55 bis 74 Jahren im Rahmen eines speziellen Programms in erfahrenen CT-Zentren angeboten werden (ESMO)</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Kann gut informierten starken Rauchern im
Alter von 55 bis 74 Jahren im Rahmen eines speziellen Programms in erfahrenen CT-Zentren angeboten werden (ESMO)</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_0uvqsz7" sourceRef="Event_0lk7fnw" targetRef="TextAnnotation_1t1txqb" />
    <bpmn2:textAnnotation id="TextAnnotation_1vyiqzt">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">with reference to national/international lung
          cancer guidelines</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">unter Bezug auf nationale/ internationale
Leitlinien zu Lungenkrebs</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>unter Bezug auf nationale/ internationale
Leitlinien zu Lungenkrebs</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_1hvq9ik">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">= exclusive, event-based gateway (if one of
          the following events occurs, after-care ends)</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">= exklusives, ereignisbasiertes Gateway (wenn
          eines der folgenden Ereignisse eintritt, endet die Nachsorge)</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>= exklusives, ereignisbasiertes Gateway (wenn
          eines der folgenden Ereignisse eintritt, endet die Nachsorge)</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="TextAnnotation_0bz1ngb">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">optional, according to national standards/
          conditions</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">optional, gemäß nationalen
Standards/Rahmenbedingungen</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>optional, gemäß nationalen
Standards/Rahmenbedingungen</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_0lk8h3z" associationDirection="None" sourceRef="Activity_1kfbd29" targetRef="TextAnnotation_0si34sk" />
    <bpmn2:textAnnotation id="TextAnnotation_18ocbdb">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">prerequisite is a formal tumour board
          decision from one of the CCCN partners</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Voraussetzung ist eine formale
Tumorboard-Entscheidung eines Leistungserbringers der beteiligten Fachgebiete</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Voraussetzung ist eine formale
Tumorboard-Entscheidung eines Leistungserbringers der beteiligten Fachgebiete</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1hxfq3m" associationDirection="None" sourceRef="Event_0ob48r7" targetRef="TextAnnotation_18ocbdb" />
    <bpmn2:textAnnotation id="TextAnnotation_00rg0wp">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">in parallel to therapy; aim: maintain and
          improve quality of life [see LC SoS 1.2.5] e.g., by nutritial counselling [LC SoS 1.9.2],
          pain management and relief according to the WHO pain management scheme, psycho-oncological
          assessment and care [LC SoS 1.4], psychosocial care, spiritual care [LC SoS 1.9.4],
          palliative care [LC SoS 9]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">parallel zur Therapie; Ziel: Erhalt und
          Verbesserung der Lebensqualität [siehe LC SoS 1.2.5], z. B. durch Ernährungsberatung [LC
          SoS 1.9.2], Schmerztherapie und Linderung nach dem WHO-Stufenschema, psychoonkologische
          Beurteilung und Versorgung [LC SoS 1.4], psychosoziale Versorgung, spirituelle Begleitung
          [LC SoS 1.9.4], palliative Versorgung [LC SoS 9]</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>parallel zur Therapie; Ziel: Erhalt und
          Verbesserung der Lebensqualität [siehe LC SoS 1.2.5], z. B. durch Ernährungsberatung [LC
          SoS 1.9.2], Schmerztherapie und Linderung nach dem WHO-Stufenschema, psychoonkologische
          Beurteilung und Versorgung [LC SoS 1.4], psychosoziale Versorgung, spirituelle Begleitung
          [LC SoS 1.9.4], palliative Versorgung [LC SoS 9]</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1e4fk0h" sourceRef="Activity_0j2qg6r" targetRef="TextAnnotation_0ar7hqt" />
