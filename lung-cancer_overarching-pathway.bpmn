    <bpmn2:participant id="Participant_0d4pi4v" name="Vorlage Patientenpfad für Lungenkrebs" processRef="Process_1">
      <bpmn2:extensionElements>
        <i18n:translation xml:lang="en">Lung Cancer Patient Pathway Template for Lung Cancer CCCNs</i18n:translation>
        <i18n:translation xml:lang="de">Vorlage Patientenpfad für Lungenkrebs</i18n:translation>
        <i18n:translation xml:lang="en">Lung Cancer Patient Pathway Template for Lung
          Cancer CCCNs</i18n:translation>
        <i18n:translation xml:lang="de">Vorlage Versorgungspfad Lungenkrebs für
          Lungenkrebs-CCCNs</i18n:translation>
      </bpmn2:extensionElements>
    </bpmn2:participant>
    <bpmn2:group id="Group_01hutym" categoryValueRef="CategoryValue_09361cn" />
    <bpmn2:group id="Group_07drmqm" categoryValueRef="CategoryValue_1dj6f28" />
    <bpmn2:group id="Group_1hqhrf1" categoryValueRef="CategoryValue_1m9f9ue" />
