    <bpmn2:textAnnotation id="TextAnnotation_01moynn">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">is there a "discharge consultation" before?</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Gibt es davor ein "Entlassungsgespräch"?</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Gibt es davor ein "Entlassungsgespräch"?</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1pcgi87" associationDirection="None" sourceRef="Activity_1ssltri" targetRef="TextAnnotation_01moynn" />
    <bpmn2:textAnnotation id="TextAnnotation_0ix2m2m">
      <bpmn2:extensionElements>
        <i18n:translation target="@text" xml:lang="en">delete?</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">löschen?</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>löschen?</bpmn2:text>
