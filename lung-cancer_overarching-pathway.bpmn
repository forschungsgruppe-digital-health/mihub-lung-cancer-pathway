        <i18n:translation target="@text" xml:lang="de">Die Entscheidung des Patienten wird
          dokumentiert
          [LC SoS 1.2.2.F]</i18n:translation>
      </bpmn2:extensionElements>
      <bpmn2:text>Die Entscheidung des Patienten wird
