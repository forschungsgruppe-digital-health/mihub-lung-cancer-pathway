    <bpmn:textAnnotation id="TextAnnotation_1wjgct1">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">medical history, family history, social
          history, smoking status (survey of current status), occupational exposure</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Anamnese, Familienanamnese, Sozialanamnese,
          Raucherstatus (Erhebung des aktuellen Status), berufliche Exposition</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Anamnese, Familienanamnese, Sozialanamnese,
          Raucherstatus (Erhebung des aktuellen Status), berufliche Exposition</bpmn:text>
    </bpmn:textAnnotation>
