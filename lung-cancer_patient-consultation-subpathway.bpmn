    <bpmn:textAnnotation id="TextAnnotation_08akvol">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">offer smoking cessation programmes [LC SoS
          1.9.6]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Programme zur Raucherentwöhnung anbieten [LC
          SoS 1.9.6]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Programme zur Raucherentwöhnung anbieten [LC
