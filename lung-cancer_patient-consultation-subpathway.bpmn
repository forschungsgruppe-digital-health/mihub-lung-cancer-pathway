    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ko3y8p" associationDirection="None" sourceRef="Activity_05dte7n" targetRef="TextAnnotation_08akvol" />
    <bpmn:textAnnotation id="TextAnnotation_0w6gmmc">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">physical examination, assessing
          comorbidities, performance status assessment (ECOG, Karnofsky Performance Status Scale),
          also see [LC SoS 2.2.1]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">körperliche Untersuchung, Erfassung von
          Komorbiditäten, Beurteilung des Performance-Status (ECOG,
          Karnofsky-Performance-Status-Skala), siehe auch [LC SoS 2.2.1]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>körperliche Untersuchung, Erfassung von
          Komorbiditäten, Beurteilung des Performance-Status (ECOG,
          Karnofsky-Performance-Status-Skala), siehe auch [LC SoS 2.2.1]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ok4jv0" sourceRef="Activity_0qyawac" targetRef="TextAnnotation_0w6gmmc" />
    <bpmn:textAnnotation id="TextAnnotation_1mqvj7n">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">&lt; 60 minutes waiting time during the visit
          [LC SoS 2.1.3]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">&lt; 60 Minuten Wartezeit während des Besuchs
          [LC SoS 2.1.3]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>&lt; 60 Minuten Wartezeit während des Besuchs
          [LC SoS 2.1.3]</bpmn:text>
    </bpmn:textAnnotation>
