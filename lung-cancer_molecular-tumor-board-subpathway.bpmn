    <bpmn:textAnnotation id="TextAnnotation_0rm75di">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Documentation of the analysis tools used,
          including:
          * designation/name of the tools used with their respective versions
          * definition and specification of the calculation of metrics such as TMB (tumour
          mutational burden), HRD, MSI
          * specification of the databases
          * specification of the cut-offs (threshold values) for the individual calculations</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Dokumentation der verwendeten
          Analysewerkzeuge, unter anderem:
          * Bezeichnung/Benennung der verwendeten Werkzeuge mit den jeweiligen Versionen
          * Definition und Angabe der Berechnung von Metriken wie TMB (Tumormutationslast), HRD, MSI
          * Spezifikation der Datenbanken
          * Angabe der Cut-offs (Toleranzwerte) für die einzelnen Berechnungen</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Dokumentation der verwendeten
          Analysewerkzeuge, unter anderem:
          * Bezeichnung/Benennung der verwendeten Werkzeuge mit den jeweiligen Versionen
          * Definition und Angabe der Berechnung von Metriken wie TMB (Tumormutationslast), HRD, MSI
          * Spezifikation der Datenbanken
          * Angabe der Cut-offs (Toleranzwerte) für die einzelnen Berechnungen</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1abjmmj" sourceRef="Activity_05w6tvq" targetRef="TextAnnotation_0rm75di" />
    <bpmn:textAnnotation id="TextAnnotation_1er2nm3">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Participants: pathologist, human genetics,
          haematology/oncology specialist, tumour-specific disciplines (tumour entity expert)</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Teilnehmende: Pathologe, Humangenetik,
          Hämatologie-/Onkologie-Facharzt, tumorspezifische Fachdisziplinen (Tumorentitätsexperte)</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Teilnehmende: Pathologe, Humangenetik,
          Hämatologie-/Onkologie-Facharzt, tumorspezifische Fachdisziplinen (Tumorentitätsexperte)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0fbn0uq" sourceRef="Activity_1vtq62m" targetRef="TextAnnotation_1er2nm3" />
    <bpmn:textAnnotation id="TextAnnotation_01o8n4o">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Next-generation sequencing (NGS):
          * DNA: panel
          * or WES, (WGS)
          if required, additional diagnostics:
          * RNA panel, transcriptome
          * further optional methods
          if abnormalities are found, validation by standard sequencing methods</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Next-Generation Sequencing (NGS):
          * DNA: Panel
          * oder WES, (WGS)
          bei Bedarf zusätzliche Diagnostik:
          * RNA-Panel, Transkriptom
          * weitere optionale Methoden
          bei Auffälligkeiten Validierung durch Standard-Sequenzierungsmethoden</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Next-Generation Sequencing (NGS):
          * DNA: Panel
          * oder WES, (WGS)
          bei Bedarf zusätzliche Diagnostik:
          * RNA-Panel, Transkriptom
          * weitere optionale Methoden
          bei Auffälligkeiten Validierung durch Standard-Sequenzierungsmethoden</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1mxuqd3" sourceRef="Activity_010pmlt" targetRef="TextAnnotation_01o8n4o" />
    <bpmn:textAnnotation id="TextAnnotation_116k17m">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">trial participation (early phase), off-label
          therapy, no further therapy</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Studienteilnahme (frühe Phase),
          Off-Label-Therapie, keine weitere Therapie</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Studienteilnahme (frühe Phase),
          Off-Label-Therapie, keine weitere Therapie</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1pctzl9" sourceRef="Event_0cokjfx" targetRef="TextAnnotation_116k17m" />
