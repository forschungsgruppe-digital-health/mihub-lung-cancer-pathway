  <bpmn:collaboration id="Collaboration_1e2foqa">
    <bpmn:participant id="Participant_0phwomt" name="Molekulares Tumorboard (MTB)" processRef="Process_e2faa7c4-7c7e-4408-82ce-89d081ca8a1b">
      <bpmn:extensionElements>
        <i18n:translation xml:lang="en">Molecular Tumorboard (MTB) - Lung Cancer</i18n:translation>
        <i18n:translation xml:lang="de">Molekulares Tumorboard (MTB)</i18n:translation>
      </bpmn:extensionElements>
    </bpmn:participant>
    <bpmn:group id="Group_0os8wk0" categoryValueRef="CategoryValue_0k3p2j8" />
    <bpmn:textAnnotation id="TextAnnotation_0nfd44x">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Presentation based on documented
          recommendation of a tumour entity or organ-specific tumour conference: For patients with
          advanced cancer, who
          - are foreseeably completing guideline-based therapy,
          - are able to receive molecular-based therapy according to the assessment of the clinical
          parameters,
          - agree in principle to a possible therapy based on the 
          molecular findings [LC SoS 1.2.4]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Vorstellung auf Grundlage der dokumentierten
          Empfehlung einer tumorspezifischen oder organspezifischen Tumorkonferenz: Für Patienten
          mit fortgeschrittener Krebserkrankung, die
          - die leitlinienbasierte Therapie voraussichtlich ausschöpfen,
          - anhand der klinischen Parameter für eine molekular basierte Therapie infrage kommen,
          - grundsätzlich einer möglichen Therapie auf Basis der 
          molekularen Befunde zustimmen [LC SoS 1.2.4]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Vorstellung auf Grundlage der dokumentierten
          Empfehlung einer tumorspezifischen oder organspezifischen Tumorkonferenz: Für Patienten
          mit fortgeschrittener Krebserkrankung, die
          - die leitlinienbasierte Therapie voraussichtlich ausschöpfen,
          - anhand der klinischen Parameter für eine molekular basierte Therapie infrage kommen,
          - grundsätzlich einer möglichen Therapie auf Basis der 
          molekularen Befunde zustimmen [LC SoS 1.2.4]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1qba4nr" sourceRef="StartEvent_1" targetRef="TextAnnotation_0nfd44x" />
    <bpmn:textAnnotation id="TextAnnotation_186yiw3">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">make recommendation incl. the results of any
          genetic tests available to the referring partner in the CCCN [LC SoS 1.2.4]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Empfehlung erstellen inkl. der Ergebnisse
aller genetischen Tests, die dem zuweisenden Leistungserbringer vorliegen [LC SoS 1.2.4]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Empfehlung erstellen inkl. der Ergebnisse
aller genetischen Tests, die dem zuweisenden Leistungserbringer vorliegen [LC SoS 1.2.4]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_12gwuou" associationDirection="None" sourceRef="DataObjectReference_0oer6b2" targetRef="TextAnnotation_186yiw3" />
    <bpmn:textAnnotation id="TextAnnotation_0ckkl82">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">Participants: bioinformatics, molecular
          biology, pathologist, human genetics, haematology/oncology specialist, tumour-specific
          disciplines (tumour entity expert)</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Teilnehmende: Bioinformatik,
          Molekularbiologie, Pathologe, Humangenetik, Hämatologie-/Onkologie-Facharzt,
          tumorspezifische Fachdisziplinen (Tumorentitätsexperte)</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Teilnehmende: Bioinformatik,
          Molekularbiologie, Pathologe, Humangenetik, Hämatologie-/Onkologie-Facharzt,
          tumorspezifische Fachdisziplinen (Tumorentitätsexperte)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0uxqf6y" sourceRef="Activity_1phtl9y" targetRef="TextAnnotation_0ckkl82" />
  </bpmn:collaboration>
