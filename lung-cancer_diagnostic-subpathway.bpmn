    <bpmn:textAnnotation id="TextAnnotation_19sf7d0">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">time to first pathology report (primary
          diagnosis) max. 3 working days 
          [LC SoS 2.1.3]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Zeit bis zum ersten pathologischen Befund
          (Primärdiagnose) max. 3 Arbeitstage 
          [LC SoS 2.1.3]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Zeit bis zum ersten pathologischen Befund
          (Primärdiagnose) max. 3 Arbeitstage 
          [LC SoS 2.1.3]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11f9q4r">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">according to guideline recommendations; if
          needed Liquid Biopsy</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">gemäß Leitlinienempfehlungen; bei Bedarf Liquid Biopsy</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>gemäß Leitlinienempfehlungen; bei Bedarf Liquid Biopsy</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0swazng" sourceRef="Activity_1tdn0dk" targetRef="TextAnnotation_11f9q4r" />
    <bpmn:textAnnotation id="TextAnnotation_0e70ar9">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">usually in ambulatory care; possibilities:
          X-ray thorax, PET/CT thorax/abdomen, MRI skull</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">in der Regel ambulant; Möglichkeiten:
          Thorax-Röntgen, PET/CT Thorax/Abdomen, MRT Schädel</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>in der Regel ambulant; Möglichkeiten:
          Thorax-Röntgen, PET/CT Thorax/Abdomen, MRT Schädel</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1dbypp4" sourceRef="Activity_10hbg7g" targetRef="TextAnnotation_0e70ar9" />
